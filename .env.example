# ============================================
# 환경변수 설정 파일 (샘플)
# ============================================
# 이 파일을 복사하여 .env로 저장한 뒤 실제 값을 입력하세요.
#   cp .env.example .env
#
# 주의: .env 파일은 절대 GitHub에 올리지 마세요!
# ============================================

# Claude API 키
ANTHROPIC_API_KEY=여기에_Claude_API키_입력

# 한국은행 ECOS API 키 (환율 조회용)
ECOS_API_KEY=여기에_한국은행_API키_입력
